# Studio Visagismo IA - producao
# Copie para .env e preencha apenas no servidor. Nunca publique esse arquivo.

OPENAI_API_KEY=sua-chave-openai-aqui

ANALYSIS_MODEL=gpt-5-mini
IMAGE_MODEL=gpt-image-2
IMAGE_QUALITY=medium

MAX_UPLOAD_SIZE=31457280
MAX_IMAGE_SIDE=1600
JPEG_QUALITY=90

ENVIRONMENT=production
LOG_LEVEL=ERROR
VISAGISMO_LOG_FILE=0
BASE_URL=https://gerador.spacered.com.br

SESSION_TIMEOUT=3600
REPORT_TTL=86400

DB_CONNECTION=sqlite
DB_DATABASE=data/app.sqlite
DB_HOST=localhost
DB_PORT=3306
DB_NAME=visagismo
DB_USER=usuario_mysql
DB_PASS=senha_mysql

ADMIN_EMAIL=admin@gerador.spacered.com.br
ADMIN_PASSWORD=troque-esta-senha

SUBSCRIPTION_PRICE=97.00
SUBSCRIPTION_DAYS=30
MONTHLY_TOKEN_QUOTA=30

ASAAS_ENV=sandbox
ASAAS_API_KEY=sua-chave-asaas-aqui
ASAAS_WEBHOOK_TOKEN=token-webhook-diferente-da-api-key
ASAAS_PROJECT_WALLET_ID=
ASAAS_PROJECT_SPLIT_PERCENT=0

# Defina uma senha longa temporaria para acessar producao-check.php?token=SENHA
# Remova o arquivo producao-check.php depois de validar o deploy.
DEPLOY_CHECK_TOKEN=troque-por-uma-senha-longa
